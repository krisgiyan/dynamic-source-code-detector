{
  "name": "dynamic-source-code-detector",
  "version": "0.1.1",
  "description": "Detect whether a webpage requires JavaScript rendering or can be scraped with a plain HTTP request",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "dscd": "./dist/cli.js",
    "dynamic-source-code-detector": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scraping",
    "crawler",
    "detection",
    "dynamic",
    "static",
    "ssr",
    "csr",
    "spa",
    "headless",
    "playwright",
    "rendering"
  ],
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "1.44.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/krisgiyan/dynamic-source-code-detector"
  }
}
